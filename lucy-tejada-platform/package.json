{
  "name": "lucy-tejada-platform",
  "version": "1.0.0",
  "description": "Plataforma de Gestión Institucional del Centro Cultural Lucy Tejada - Pereira, Colombia",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/*",
    "frontend/*"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:auth dev:academic dev:frontend",
    "dev:auth": "npm run dev --workspace=auth-service",
    "dev:academic": "npm run dev --workspace=academic-service",
    "dev:frontend": "npm run dev --workspace=web-app",
    "build": "npm-run-all build:*",
    "build:shared": "npm run build --workspace=@lucy-tejada/shared --if-present",
    "build:types": "npm run build --workspace=@lucy-tejada/types --if-present",
    "build:services": "npm-run-all --parallel build:auth build:academic",
    "build:auth": "npm run build --workspace=auth-service",
    "build:academic": "npm run build --workspace=academic-service",
    "build:frontend": "npm run build --workspace=web-app",
    "test": "npm-run-all test:*",
    "test:unit": "jest --config jest.config.js",
    "test:e2e": "jest --config jest.e2e.config.js",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "docker:up": "docker-compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f docker/docker-compose.yml down",
    "docker:build": "docker-compose -f docker/docker-compose.yml build",
    "docker:logs": "docker-compose -f docker/docker-compose.yml logs -f",
    "db:migrate": "npm run migrate --workspace=academic-service",
    "db:seed": "npm run seed --workspace=academic-service",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.1.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/centro-cultural-lucy-tejada/plataforma-gestion"
  },
  "author": "Centro Cultural Lucy Tejada - Alcaldía de Pereira",
  "license": "UNLICENSED",
  "dependencies": {
    "@dataconnect/generated": "file:src/dataconnect-generated"
  }
}
