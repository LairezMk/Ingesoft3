# ============================================
# PLATAFORMA CENTRO CULTURAL LUCY TEJADA
# Variables de Entorno - Configuración
# ============================================

# Ambiente
NODE_ENV=development
APP_NAME=lucy-tejada-platform
APP_VERSION=1.0.0

# ============================================
# API Gateway
# ============================================
API_GATEWAY_PORT=3000
API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_PREFIX=/api/v1

# ============================================
# Servicios - Puertos
# ============================================
AUTH_SERVICE_PORT=3001
ACADEMIC_SERVICE_PORT=3002
INFRASTRUCTURE_SERVICE_PORT=3003
REPORTS_SERVICE_PORT=3004
NOTIFICATION_SERVICE_PORT=3005

# ============================================
# Base de Datos PostgreSQL
# ============================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=lucy_tejada_db
DATABASE_USER=postgres
DATABASE_PASSWORD=your_secure_password_here
DATABASE_SSL=false
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ============================================
# Redis Cache
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_DB=0
REDIS_TTL=3600

# ============================================
# JWT Authentication
# ============================================
JWT_SECRET=your_very_long_and_secure_jwt_secret_key_min_64_chars_recommended
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your_refresh_token_secret_key_different_from_access_token
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# AWS S3 - Almacenamiento de Archivos
# ============================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=lucy-tejada-files
AWS_S3_ENDPOINT=

# ============================================
# Email - SMTP Configuration
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@lucytejada.gov.co
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_NAME=Centro Cultural Lucy Tejada
SMTP_FROM_EMAIL=noreply@lucytejada.gov.co

# ============================================
# Logs y Monitoreo
# ============================================
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_FILE_PATH=./logs

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# CORS
# ============================================
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# ============================================
# Frontend
# ============================================
VITE_API_URL=http://localhost:3000/api/v1
VITE_APP_NAME=Centro Cultural Lucy Tejada
VITE_APP_VERSION=1.0.0

# ============================================
# Encriptación de Datos Sensibles (Ley 1581)
# ============================================
ENCRYPTION_KEY=your_32_byte_encryption_key_here
ENCRYPTION_ALGORITHM=aes-256-gcm
