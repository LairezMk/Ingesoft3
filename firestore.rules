rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function currentUserPath() {
      return /databases/$(database)/documents/user_profiles/$(request.auth.uid);
    }

    function currentUserDoc() {
      return get(currentUserPath());
    }

    function currentUserExists() {
      return isSignedIn() && exists(currentUserPath());
    }

    function currentRole() {
      return currentUserExists()
        ? currentUserDoc().data.role
        : null;
    }

    function isAdmin() {
      return currentRole() == 'ADMIN';
    }

    function isTeacher() {
      return currentRole() == 'DOCENTE';
    }

    function isStudent() {
      return currentRole() == 'ESTUDIANTE';
    }

    match /programs/{document=**} {
      allow read: if true;
      allow write: if isAdmin() || isTeacher();
    }

    match /venues/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reservations/{reservationId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin() || isTeacher() || isStudent();
    }

    match /teachers/{teacherId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /students/{studentId} {
      allow read: if isAdmin() || isTeacher() || (isStudent() && request.auth.uid == studentId);
      allow create: if isAdmin() || request.auth.uid == studentId;
      allow update: if isAdmin() || request.auth.uid == studentId;
      allow delete: if isAdmin();
    }

    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isTeacher();
    }

    match /enrollments/{enrollmentId} {
      allow read: if isAdmin() || isTeacher() || isStudent();
      allow create: if isSignedIn() || true;
      allow update, delete: if isAdmin() || isTeacher();
    }

    match /contracts/{contractId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /maintenance_records/{recordId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /attendance_records/{recordId} {
      allow read: if isAdmin() || isTeacher() || isStudent();
      allow write: if isAdmin() || isTeacher();
    }

    match /evaluations/{evaluationId} {
      allow read: if isAdmin() || isTeacher() || isStudent();
      allow write: if isAdmin() || isTeacher();
    }

    match /user_profiles/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }
  }
}
